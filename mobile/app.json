{
  "expo": {
    "name": "Recurlog",
    "slug": "recurlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0B1E3D",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recurlog.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1E3D"
      },
      "package": "com.recurlog.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "sdkVersion": "54.0.0",
    "extra": {
      "eas": {
        "projectId": "28d21533-210c-47a9-8c6d-dfd7c76268b1"
      }
    },
    "owner": "devbarat"
  }
}
